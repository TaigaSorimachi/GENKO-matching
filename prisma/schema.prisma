generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ユーザー種別
enum UserType {
  JOBSEEKER
  EMPLOYER
}

// 求人ステータス
enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  EXPIRED
}

// 求人の緊急度
enum JobUrgency {
  NORMAL
  URGENT
  EMERGENCY
}

// シフト種別
enum ShiftType {
  FULL_TIME
  PART_TIME
  SPOT
  CONTRACT
}

// マッチングステータス
enum MatchStatus {
  SUGGESTED
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

// メッセージ種別
enum MessageType {
  TEXT
  IMAGE
  VOICE
  TEMPLATE
}

// 業界
enum Industry {
  CONSTRUCTION
  MANUFACTURING
  TRANSPORT
  LOGISTICS
  SECURITY
  NURSING
  CLEANING
  OTHER
}

// ユーザー
model User {
  id          String   @id @default(cuid())
  type        UserType
  phone       String   @unique
  name        String
  location    String?
  lat         Float?
  lng         Float?
  language    String   @default("ja")
  trustScore  Int      @default(0)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skills          UserSkill[]
  reviewsGiven    Review[]        @relation("ReviewerRelation")
  reviewsReceived Review[]        @relation("RevieweeRelation")
  matches         Match[]
  sentMessages    Message[]       @relation("SenderRelation")
  receivedMessages Message[]      @relation("ReceiverRelation")

  @@map("users")
}

// 企業
model Company {
  id         String   @id @default(cuid())
  name       String
  industry   Industry
  size       Int?
  address    String?
  lat        Float?
  lng        Float?
  verified   Boolean  @default(false)
  trustScore Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users User[]
  jobs  Job[]

  @@map("companies")
}

// スキル
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  industry  Industry
  equivIntl String?
  createdAt DateTime @default(now())

  userSkills  UserSkill[]
  jobSkills   JobSkill[]

  @@map("skills")
}

// ユーザースキル（中間テーブル）
model UserSkill {
  id        String  @id @default(cuid())
  userId    String
  skillId   String
  level     Int     @default(1)
  verified  Boolean @default(false)
  certImage String?
  xpPoints  Int     @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

// 求人
model Job {
  id          String     @id @default(cuid())
  companyId   String
  title       String
  description String
  salaryMin   Int?
  salaryMax   Int?
  location    String
  lat         Float?
  lng         Float?
  shiftType   ShiftType
  urgency     JobUrgency @default(NORMAL)
  status      JobStatus  @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills   JobSkill[]
  matches  Match[]
  reviews  Review[]

  @@map("jobs")
}

// 求人スキル要件（中間テーブル）
model JobSkill {
  id       String @id @default(cuid())
  jobId    String
  skillId  String
  minLevel Int    @default(1)

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@map("job_skills")
}

// マッチング
model Match {
  id        String      @id @default(cuid())
  userId    String
  jobId     String
  aiScore   Float?
  status    MatchStatus @default(SUGGESTED)
  appliedAt DateTime?
  hiredAt   DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("matches")
}

// レビュー
model Review {
  id          String @id @default(cuid())
  reviewerId  String
  revieweeId  String
  jobId       String
  rating      Int
  safetyScore Int?
  comment     String?
  createdAt   DateTime @default(now())

  reviewer User @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User @relation("RevieweeRelation", fields: [revieweeId], references: [id], onDelete: Cascade)
  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// メッセージ
model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  type       MessageType @default(TEXT)
  content    String
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())

  sender   User @relation("SenderRelation", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceiverRelation", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}
